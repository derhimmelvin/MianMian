###########################################
# 1. 基础环境与 IDE 忽略 (Windows/macOS/JetBrains/VSCode)
###########################################
# OS files
.DS_Store
**/.DS_Store
*:Zone.Identifier

# JetBrains (IntelliJ, WebStorm, etc.)
.idea/
*.iws
*.iml
*.ipr
out/
gen/

# VS Code
.vscode/

###########################################
# 2. 前端项目忽略 (mianmian_frontend)
###########################################
# 依赖
**/node_modules/
**/.pnp
**/.pnp.js
**/.yarn/install-state.gz

# Next.js & 构建输出
**/.next/
**/out/
**/build/
**/dist/
**/coverage/

# 日志与调试
**/*.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
**/*.tsbuildinfo
**/next-env.d.ts

# Vercel
**/.vercel

###########################################
# 3. 后端项目忽略 (Java/Maven/Spring)
###########################################
# 编译输出
**/target/
**/build/
**/bin/

# Maven 运行支持
!.mvn/wrapper/maven-wrapper.jar
.mvn/timing.properties
release.properties
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next

# STS / Eclipse 特有
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

###########################################
# 4. 通用敏感信息与配置文件
###########################################
# 忽略所有环境配置文件 (极其重要)
**/*.env
**/*.env*.local

# 忽略密钥文件
**/*.pem
**/*.jks
**/*.p12

# 忽略所有打包后的压缩/安装包
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
